fn fib(n: i64) -> i64 {
    let mut i: i64 = 0;
    let mut a: i64 = 0;
    let mut b: i64 = 1;
    while i < n {
        let temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    a
}

fn main() -> i64 {
    let mut idx: i64 = 0;
    let mut acc: i64 = 0;
    for (idx = 0; idx < 5; idx = idx + 1) {
        acc = acc + fib(idx);
    }
    acc
}
